generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum LeadStatus {
  RAW
  ENRICHED
  SEQUENCED
  SENT
  REPLIED
  BOOKED
  SUPPRESSED
}

model Lead {
  id                String     @id @default(uuid())
  name              String
  title             String?
  company           String?
  linkedinUrl       String?    @unique
  country           String?
  // ── Personalization signals (research-backed model, March 2026) ──────────
  companyNewsEvent        String?  // Priority A: WARN Act, SEC 8-K, reorg, layoffs (macro, public)
  recentPostSummary       String?  // Priority B: post topic paraphrase (never verbatim)
  careerTrigger           String?  // Signal type: layoff / job change / burnout / opentowork
  franchiseAngle          String?  // Internal context — not referenced in email
  yearsInCurrentRole      Int?     // Scoring signal only — NEVER passed to email generator
  // Legacy fields — no longer populated, kept for existing rows
  pulledQuoteFromPost     String?  // BLACKLISTED
  specificProjectOrMetric String?  // BLACKLISTED
  placeOrPersonalDetail   String?  // BLACKLISTED
  email             String?
  score             Int        @default(0)
  status            LeadStatus @default(RAW)
  draftEmail        String?
  
  // Relations
  replies           Reply[]
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model SuppressionList {
  id        String   @id @default(uuid())
  email     String?  @unique
  domain    String?  @unique
  reason    String?
  createdAt DateTime @default(now())
}

model Reply {
  id             String   @id @default(uuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id])
  content        String
  classification String?  // e.g. "Interested", "Not a fit", "Unsubscribe"
  createdAt      DateTime @default(now())
}

model SystemSettings {
  id             String   @id @default("singleton")
  openAiApiKey   String?
  resendApiKey   String?
  maxSendsPerDay Int      @default(15)
  updatedAt      DateTime @updatedAt
}
